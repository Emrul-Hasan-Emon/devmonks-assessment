{
  "name": "api",
  "version": "1.0.3",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:poisa": "ts-node-dev --respawn --transpile-only src/main.ts --max-old-space-size=256",
    "start:work": "ts-node-dev --respawn --transpile-only -r tsconfig-paths/register src/main.ts ",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node --env-file .env dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "migration:generate": "typeorm-ts-node-commonjs migration:generate src/modules/database/migrations/migrations -d src/ormconfig.ts",
    "migration:run": "typeorm-ts-node-commonjs -d src/ormconfig.ts migration:run",
    "migration:reset": "typeorm-ts-node-commonjs -d src/ormconfig.ts schema:sync && typeorm-ts-node-commonjs -d src/ormconfig.ts schema:drop",
    "migration:revert": "typeorm-ts-node-commonjs -d src/ormconfig.ts migration:revert",
    "seed:config": "ts-node ./node_modules/typeorm-seeding/dist/cli.js config -n /Users/piash/Developer/shukhee-code/shukhee-api/src/database/mysql/ormconfig.ts",
    "seed:run": "ts-node ./node_modules/typeorm-seeding/dist/cli.js seed -n /Users/piash/Developer/shukhee-code/shukhee-api/src/database/mysql/mysql.config-migrations.ts",
    "seed:create": "ts-node ./node_modules/typeorm-extension/bin/cli.cjs -d src/ormconfig.ts seed:create",
    "sentry:sourcemaps": "sentry-cli sourcemaps inject --org grameen-telecom-trust --project shukhee-api ./dist && sentry-cli sourcemaps upload --org grameen-telecom-trust --project shukhee-api ./dist"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.588.0",
    "@aws-sdk/lib-storage": "^3.588.0",
    "@nestjs/axios": "^3.0.2",
    "@nestjs/cache-manager": "^2.3.0",
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^3.2.2",
    "@nestjs/core": "^10.0.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/mapped-types": "^2.0.5",
    "@nestjs/microservices": "^10.3.8",
    "@nestjs/platform-express": "^10.3.8",
    "@nestjs/serve-static": "^4.0.2",
    "@nestjs/throttler": "^6.3.0",
    "@nestjs/typeorm": "^10.0.2",
    "@sentry/cli": "^2.32.1",
    "@sentry/node": "^8.8.0",
    "aws-sdk": "^2.1632.0",
    "axios": "^1.6.8",
    "bcrypt": "^5.1.1",
    "cache-manager": "^5.7.6",
    "cache-manager-redis-store": "^3.0.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "csv-parser": "^3.0.0",
    "exceljs": "^4.4.0",
    "handlebars": "^4.7.8",
    "ioredis": "^5.5.0",
    "moment": "^2.30.1",
    "moment-timezone": "^0.5.46",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "multer-s3": "^3.0.1",
    "mysql2": "^3.9.7",
    "path": "^0.12.7",
    "pg": "^8.20.0",
    "rxjs": "^7.8.1",
    "slugify": "^1.6.6",
    "typeorm": "^0.3.20",
    "typeorm-extension": "^3.5.1",
    "uuid": "^9.0.1",
    "xlsx": "^0.18.5",
    "zeptomail": "^6.0.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@types/cookie-parser": "^1.4.7",
    "@types/express": "^4.17.17",
    "@types/jest": "^29.5.2",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.3.1",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^6.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.42.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "jest": "^29.5.0",
    "jsonwebtoken": "^9.0.2",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "prettier": "^3.0.0",
    "source-map-support": "^0.5.21",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.0",
    "ts-loader": "^9.4.3",
    "ts-node": "^10.9.1",
    "ts-node-dev": "^2.0.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.1.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
